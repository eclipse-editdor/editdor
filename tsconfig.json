{
  "compilerOptions": {
    "target": "es2020",
    "jsx": "react-jsx",
    "module": "esnext",
    "rootDir": "./src",
    "typeRoots": [
      "./src/types",
      "./node_modules/@types",
      "./node_modules/@wot-thing-description-types",
      "./node_modules/wot-typescript-definitions"
    ],
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "build",
    "stripInternal": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["src", "env.d.ts"],
  "exclude": ["build"]
}
